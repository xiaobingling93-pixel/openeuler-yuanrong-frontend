{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Function Invocations Total",
      "type": "graph",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(function_invocations_total{akernel_env=~\"$akernel_env\"}[5m])) by (function_name, http_code)",
          "legendFormat": "{{function_name}} - {{http_code}}",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "ops",
          "label": "Requests/sec (ops)"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      }
    },
    {
      "id": 2,
      "title": "Function Invocation Duration",
      "type": "graph",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(function_invocation_duration_seconds_bucket{akernel_env=~\"$akernel_env\"}[5m])) by (le, function_name))",
          "legendFormat": "p95 - {{function_name}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(function_invocation_duration_seconds_bucket{akernel_env=~\"$akernel_env\"}[5m])) by (le, function_name))",
          "legendFormat": "p99 - {{function_name}}",
          "refId": "B"
        },
        {
          "expr": "sum(rate(function_invocation_duration_seconds_sum{akernel_env=~\"$akernel_env\"}[5m])) / sum(rate(function_invocation_duration_seconds_count{akernel_env=~\"$akernel_env\"}[5m])) by (function_name)",
          "legendFormat": "avg - {{function_name}}",
          "refId": "C"
        }
      ],
      "yaxes": [
        {
          "format": "s",
          "label": "Duration (s)"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      }
    },
    {
      "id": 3,
      "title": "HTTP Status Code Distribution",
      "type": "piechart",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(function_invocations_total{akernel_env=~\"$akernel_env\"}) by (http_code)",
          "legendFormat": "{{http_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Function Invocation Count by Function",
      "type": "table",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(function_invocations_total{akernel_env=~\"$akernel_env\"}) by (function_name, http_code)",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {},
            "renameByName": {
              "function_name": "Function Name",
              "http_code": "HTTP Code",
              "Value": "Count"
            }
          }
        }
      ]
    },
    {
      "id": 5,
      "title": "Error Rate",
      "type": "graph",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "sum(rate(function_invocations_total{akernel_env=~\"$akernel_env\",http_code=~\"5..\"}[5m])) / sum(rate(function_invocations_total{akernel_env=~\"$akernel_env\"}[5m]))",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "yaxes": [
        {
          "format": "percentunit",
          "label": "Error Rate (%)"
        },
        {
          "format": "short"
        }
      ],
      "xaxis": {
        "mode": "time"
      }
    },
    {
      "id": 6,
      "title": "Request Rate by Function",
