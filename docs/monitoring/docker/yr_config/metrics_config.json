{
  "backends": [
    {
      "batchExport": {
        "name": "akernel",
        "enable": true,
        "exporters": [
          {
            "opentelemetryExporter": {
              "enable": true,
              "batchSize": 100,
              "batchIntervalSec": 5,
              "failureQueueMaxSize": 3,
              "failureDataDir": "/tmp/metrics/failure",
              "failureDataFileMaxCapacity": 20,
              "enabledInstruments": [
                "yr_nodes_cpu_allocatable",
                "yr_nodes_cpu_capacity",
                "yr_nodes_memory_allocatable",
                "yr_nodes_memory_capacity",
                "yr_cluster_cpu_capacity",
                "yr_cluster_cpu_allocatable",
                "yr_cluster_memory_capacity",
                "yr_cluster_memory_allocatable",
                "yr_instance_count",
                "yr_cluster_instance_total"
              ],
              "initConfig": {
                "endpoint": "http://localhost:4318/v1/metrics"
              }
            }
          }
        ]
      }
    }
  ]
}